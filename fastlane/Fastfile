default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight, then submit for App Store review"
  lane :submit do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_content:  ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: false
    )

    sh("xcodegen generate --spec ../project.yml")

    build_app(
      scheme:              "SnapMath",
      project:             "SnapMath.xcodeproj",
      configuration:       "Release",
      output_directory:    "./build",
      output_name:         "SnapMath.ipa",
      export_method:       "app-store",
      xcargs:              "DEVELOPMENT_TEAM=#{ENV["DEVELOPMENT_TEAM"]} ANTHROPIC_API_KEY=#{ENV["ANTHROPIC_API_KEY"]}",
      clean:               true
    )

    upload_to_testflight(
      api_key:                          api_key,
      ipa:                              "./build/SnapMath.ipa",
      skip_waiting_for_build_processing: false,
      distribute_external:              false
    )

    deliver(
      api_key:        api_key,
      ipa:            "./build/SnapMath.ipa",
      app_identifier: "com.kokicoder.snapmath",
      name:           "SnapMath - AI Math Solver",
      description:    {
        "en-US" => File.read("app_store/description_en.txt"),
        "ja"    => File.read("app_store/description_ja.txt")
      },
      keywords: {
        "en-US" => "math solver,ai math,camera calculator,step by step math,algebra solver,equation solver,homework help,math tutor",
        "ja"    => "数学ソルバー,AI数学,カメラ計算機,数式解説,代数,方程式,宿題サポート,数学家庭教師"
      },
      release_notes: {
        "en-US" => File.read("app_store/whats_new_en.txt"),
        "ja"    => File.read("app_store/whats_new_ja.txt")
      },
      primary_category:   "EDUCATION",
      secondary_category: "UTILITIES",
      privacy_url:        "https://github.com/Koki-coder-crypto/LynQ_backend/blob/master/app_store/privacy_policy.html",
      support_url:        "https://github.com/Koki-coder-crypto/LynQ_backend/issues",
      price_tier:         0,
      submission_information: {
        export_compliance_uses_encryption:           false,
        export_compliance_is_exempt:                 true,
        add_id_info_uses_idfa:                       false,
        add_id_info_serves_ads:                      false,
        add_id_info_tracks_action:                   false,
        add_id_info_tracks_install:                  false,
        add_id_info_limits_tracking:                 true,
        content_rights_has_rights:                   true,
        content_rights_contains_third_party_content: false
      },
      submit_for_review:  true,
      automatic_release:  false,
      skip_screenshots:   true,
      skip_metadata:      false,
      force:              true
    )

    UI.success("SnapMath submitted for App Store review!")
  end

  desc "Build only (no upload)"
  lane :build_only do
    sh("xcodegen generate --spec ../project.yml")
    build_app(
      scheme:           "SnapMath",
      project:          "SnapMath.xcodeproj",
      configuration:    "Release",
      output_directory: "./build",
      output_name:      "SnapMath.ipa",
      export_method:    "app-store",
      xcargs:           "DEVELOPMENT_TEAM=#{ENV["DEVELOPMENT_TEAM"]} ANTHROPIC_API_KEY=#{ENV["ANTHROPIC_API_KEY"]}",
      clean: true
    )
  end

end
